---
import Base from '../../layouts/Base.astro'
import articles from '../../../../app/public/data/articles.json'

export function getStaticPaths() {
  return articles.map(a => ({ params: { id: a.id }, props: { article: a } }))
}

const { article } = Astro.props
---
<Base title={`${article.title} — Digitalfire`}>
  <div class="max-w-3xl mx-auto">
    <a href="/articles" class="text-sm text-neutral-400 hover:text-neutral-600 mb-6 inline-block">← Articles</a>
    {article.plainsman && (
      <div class="mb-4 rounded border border-amber-200 bg-amber-50 px-4 py-2 text-sm text-amber-700">
        This article contains Plainsman-specific content.
      </div>
    )}
    <h1 class="text-2xl font-semibold text-neutral-900 mb-6">{article.title}</h1>
    <div class="prose" set:html={article.body} />
    <div class="mt-10 border-t border-neutral-100 pt-4 text-xs text-neutral-400">
      Content by Tony Hansen · Originally published on Digitalfire.com
    </div>
  </div>
</Base>
